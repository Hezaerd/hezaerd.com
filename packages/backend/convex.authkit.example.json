{
  "$schema": "./node_modules/convex/schemas/convex.schema.json",
  "functions": "convex/",
  "aiFiles": {
    "enabled": false
  },
  "authKit": {
    "dev": {
      "configure": {
        "redirectUris": ["http://localhost:3002/api/auth/callback"],
        "appHomepageUrl": "http://localhost:3002",
        "corsOrigins": ["http://localhost:3002"]
      },
      "localEnvVars": {
        "WORKOS_CLIENT_ID": "${authEnv.WORKOS_CLIENT_ID}",
        "WORKOS_API_KEY": "${authEnv.WORKOS_API_KEY}"
      }
    },
    "preview": {
      "configure": {
        "redirectUris": ["https://${buildEnv.VERCEL_BRANCH_URL}/api/auth/callback"],
        "appHomepageUrl": "https://${buildEnv.VERCEL_PROJECT_PRODUCTION_URL}",
        "corsOrigins": ["https://${buildEnv.VERCEL_BRANCH_URL}"]
      }
    },
    "prod": {
      "environmentType": "production",
      "configure": {
        "redirectUris": ["https://${buildEnv.VERCEL_PROJECT_PRODUCTION_URL}/api/auth/callback"],
        "appHomepageUrl": "https://${buildEnv.VERCEL_PROJECT_PRODUCTION_URL}",
        "corsOrigins": ["https://${buildEnv.VERCEL_PROJECT_PRODUCTION_URL}"]
      }
    }
  }
}
