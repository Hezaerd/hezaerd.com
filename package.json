{
  "name": "hezaerd",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "^7.0.2"
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:brand": "turbo run dev --filter=@hezaerd/brand",
    "dev:portfolio": "turbo run dev --filter=@hezaerd/portfolio",
    "build": "turbo run build",
    "build:brand": "turbo run build --filter=@hezaerd/brand",
    "build:portfolio": "turbo run build --filter=@hezaerd/portfolio",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt .",
    "typecheck": "turbo run typecheck",
    "check": "bun run lint && bun run format && bun run typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.5.4",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.2.19"
}
